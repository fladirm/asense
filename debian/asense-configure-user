#!/bin/sh
set -eu

template=/usr/libexec/asense/asense.socket.in
state_dir=/etc/asense
state_file=$state_dir/desktop-user
socket_unit=/etc/systemd/system/asense.socket

usage() {
    cat <<'EOF'
Usage: sudo asense-configure-user USER
       sudo asense-configure-user --auto

Configure the non-root desktop account allowed to connect to the ASense
control socket. --auto keeps an existing configuration or chooses the single
active/local desktop account when that is unambiguous.
EOF
}

account_details() {
    candidate=$1
    case "$candidate" in
        ''|*[!A-Za-z0-9_.@-]*) return 1 ;;
    esac

    entry=$(getent passwd "$candidate" 2>/dev/null) || return 1
    user=$(printf '%s\n' "$entry" | cut -d: -f1)
    uid=$(printf '%s\n' "$entry" | cut -d: -f3)
    [ "$uid" -gt 0 ] || return 1
    group=$(id -gn "$user" 2>/dev/null) || return 1
    case "$group" in
        ''|*[!A-Za-z0-9_.@-]*) return 1 ;;
    esac
    return 0
}

existing_user() {
    if [ -r "$state_file" ]; then
        sed -n '1p' "$state_file"
        return
    fi
    if [ -r "$socket_unit" ]; then
        sed -n 's/^SocketUser=//p' "$socket_unit" | sed -n '1p'
    fi
}

active_users() {
    command -v loginctl >/dev/null 2>&1 || return 0
    loginctl list-sessions --no-legend 2>/dev/null |
        while read -r session _uid name _rest; do
            [ -n "$session" ] || continue
            [ "$(loginctl show-session "$session" -p Active --value 2>/dev/null || true)" = yes ] || continue
            [ "$(loginctl show-session "$session" -p Remote --value 2>/dev/null || true)" = no ] || continue
            printf '%s\n' "$name"
        done
}

single_regular_user() {
    getent passwd | awk -F: '$3 >= 1000 && $3 < 60000 && $6 ~ /^\/home\// { print $1 }'
}

auto_user() {
    saved=$(existing_user || true)
    if [ -n "$saved" ] && account_details "$saved"; then
        printf '%s\n' "$user"
        return 0
    fi

    candidates=$(active_users | sort -u)
    count=$(printf '%s\n' "$candidates" | sed '/^$/d' | wc -l)
    if [ "$count" -eq 1 ]; then
        candidate=$(printf '%s\n' "$candidates" | sed -n '1p')
        if account_details "$candidate"; then
            printf '%s\n' "$user"
            return 0
        fi
    fi

    candidates=$(single_regular_user | sort -u)
    count=$(printf '%s\n' "$candidates" | sed '/^$/d' | wc -l)
    if [ "$count" -eq 1 ]; then
        candidate=$(printf '%s\n' "$candidates" | sed -n '1p')
        if account_details "$candidate"; then
            printf '%s\n' "$user"
            return 0
        fi
    fi
    return 1
}

[ "$(id -u)" -eq 0 ] || {
    echo "asense-configure-user must run as root" >&2
    exit 1
}

case "${1:-}" in
    -h|--help)
        usage
        exit 0
        ;;
    --auto)
        selected=$(auto_user) || {
            echo "ASense: no unambiguous desktop account was found." >&2
            echo "Run: sudo asense-configure-user USER" >&2
            exit 2
        }
        ;;
    '')
        usage >&2
        exit 2
        ;;
    *)
        selected=$1
        ;;
esac

[ -r "$template" ] || {
    echo "ASense socket template is missing: $template" >&2
    exit 1
}

account_details "$selected" || {
    echo "Invalid non-root local account: $selected" >&2
    exit 2
}

tmp=$(mktemp /tmp/asense.socket.XXXXXX)
state_tmp=$(mktemp /tmp/asense.desktop-user.XXXXXX)
trap 'rm -f "$tmp" "$state_tmp"' EXIT HUP INT TERM
awk -v socket_user="$user" -v socket_group="$group" '
    { gsub(/@TARGET_USER@/, socket_user); gsub(/@TARGET_GROUP@/, socket_group); print }
' "$template" >"$tmp"

install -d -o root -g root -m 0755 "$state_dir" /etc/systemd/system
printf '%s\n' "$user" >"$state_tmp"
install -o root -g root -m 0644 "$state_tmp" "$state_file"
install -o root -g root -m 0644 "$tmp" "$socket_unit"

if [ -d /run/systemd/system ]; then
    systemctl stop asense.service asense.socket >/dev/null 2>&1 || true
    systemctl daemon-reload
    systemctl enable --now asense.socket
fi

if [ "$(cat /sys/class/dmi/id/product_name 2>/dev/null || true)" = \
    "Predator PHN16-72" ] &&
    [ -x /usr/libexec/asense/asense-shortcut ]; then
    /usr/libexec/asense/asense-shortcut install "$user" ||
        echo "ASense: Predator-key shortcut setup is pending; rerun this command after login." >&2
fi

echo "ASense control socket configured for $user:$group"
